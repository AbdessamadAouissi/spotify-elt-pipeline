# ──────────────────────────────────────────────────────────────
# Spotify API — https://developer.spotify.com/dashboard
# ──────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ──────────────────────────────────────────────────────────────
# Google Cloud Platform
# ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your_gcp_project_id
GCS_BUCKET_NAME=your_gcs_bucket_name
GCS_BRONZE_PREFIX=bronze

# BigQuery datasets (créés automatiquement au premier run)
BIGQUERY_DATASET_BRONZE=spotify_bronze
BIGQUERY_DATASET_SILVER=spotify_silver
BIGQUERY_DATASET_GOLD=spotify_gold

# ──────────────────────────────────────────────────────────────
# Paramètres d'extraction Spotify
# ──────────────────────────────────────────────────────────────
# Query pour albums et tracks (supporte year: filter)
SPOTIFY_SEARCH_QUERY=year:2020-2026

# Query pour artistes (year: ne fonctionne pas — utiliser un genre ou nom)
SPOTIFY_SEARCH_QUERY_ARTISTS=rap francais

# Query pour playlists
SPOTIFY_SEARCH_QUERY_PLAYLISTS=rap francais

# Marché Spotify (ISO 3166-1 alpha-2)
SPOTIFY_MARKET=FR

# Nombre max de pages par ressource (10 items/page max depuis 2025)
MAX_PAGES=10
